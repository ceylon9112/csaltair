{
  "name": "jazz-fest-2026",
  "main": "expo-router/entry",
  "version": "1.0.0-beta.1",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --localhost",
    "web:lan": "expo start --web --lan",
    "web:tunnel": "expo start --web --tunnel",
    "web:vite": "npm install --prefix patron-web --no-audit --no-fund && npm --prefix patron-web run dev",
    "build:web:vite": "npm --prefix patron-web run build",
    "open": "node scripts/open-localhost.mjs",
    "open:vite": "node scripts/open-vite.mjs",
    "export:web": "expo export --platform web --output-dir dist-web",
    "beta:check": "npm test && npx tsc --noEmit && npm run lint && npx expo-doctor",
    "build:android:preview": "npx eas-cli build --profile preview --platform android",
    "build:ios:preview": "npx eas-cli build --profile preview --platform ios",
    "test": "jest",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.96.2",
    "@types/jest": "29.5.14",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
